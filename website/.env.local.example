# Copy this file to .env.local (which is git-ignored — never commit real secrets) and fill in
# the real values below. Get these from:
#   - Supabase: Project Settings -> API (in your Supabase project dashboard)
#   - TMDB: Settings -> API (in your TMDB account)

# Safe to expose in browser JS (Next.js's NEXT_PUBLIC_ prefix does this on purpose).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# This site's own base URL (e.g. https://episode-ranker.vercel.app, or http://localhost:3000 for
# local dev) — no trailing slash. Used as the `redirectTo` for Supabase's password-reset email
# (see src/app/forgot-password/actions.ts); there was no existing env var for "this site's own
# URL" before that feature needed one.
NEXT_PUBLIC_SITE_URL=

# Server-only — never prefix these with NEXT_PUBLIC_, and never expose them to the browser.
SUPABASE_SECRET_KEY=
TMDB_API_READ_ACCESS_TOKEN=
